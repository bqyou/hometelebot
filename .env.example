# ============================================================
# TeleBot Platform Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Telegram Bot ---
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# --- Database ---
# For local development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./telebot.db

# For production (PostgreSQL on Neon/Supabase):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# --- Authentication ---
# Session duration in hours (default: 24)
SESSION_DURATION_HOURS=24

# Maximum failed login attempts before lockout (default: 5)
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes after max failed attempts (default: 15)
LOCKOUT_DURATION_MINUTES=15

# --- Web Scraping ---
# How often to check for new tingkat menu (in seconds)
# Default: 86400 (24 hours). The scraper compares date ranges
# so frequent checks are harmless.
MENU_SCRAPE_INTERVAL_SECONDS=86400

# --- Server ---
# Set to "webhook" for production, "polling" for local dev
BOT_MODE=polling

# Only needed if BOT_MODE=webhook
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_PORT=8443

# --- Logging ---
LOG_LEVEL=INFO
